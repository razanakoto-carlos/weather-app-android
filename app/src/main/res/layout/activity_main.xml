<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════ -->
    <!-- BARRE DE RECHERCHE                         -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchView"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_search"
        app:queryHint="Rechercher une ville..."
        app:iconifiedByDefault="false"
        app:queryBackground="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════ -->
    <!-- BLOC PRINCIPAL : Ville + Date              -->
    <!-- ══════════════════════════════════════════ -->
    <TextView
        android:visibility="invisible"
        android:id="@+id/tvCity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Milano"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchView" />

    <TextView
        android:id="@+id/tvDate"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Vendredi 13 mai"
        android:textColor="#6B8CAE"
        android:textSize="14sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCity" />

    <!-- ══════════════════════════════════════════ -->
    <!-- BLOC TEMPÉRATURE + ICÔNE                   -->
    <!-- centré horizontalement, icône à droite     -->
    <!-- ══════════════════════════════════════════ -->
    <TextView
        android:visibility="invisible"
        android:id="@+id/tvTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="20°"
        android:textColor="#FFFFFF"
        android:textSize="60sp"
        android:fontFamily="sans-serif-thin"
        app:layout_constraintEnd_toStartOf="@id/ivWeatherIcon"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDate" />

    <ImageView
        android:visibility="invisible"
        android:id="@+id/ivWeatherIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="12dp"
        android:src="@drawable/ic_soleil"
        app:layout_constraintBottom_toBottomOf="@id/tvTemperature"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvTemperature"
        app:layout_constraintTop_toTopOf="@id/tvTemperature"
        app:layout_constraintVertical_bias="0.55" />

    <!-- ══════════════════════════════════════════ -->
    <!-- DÉTAILS : max/min/vent/humidité            -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:visibility="invisible"
        android:id="@+id/llDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:padding="12dp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTemperature">

        <!-- Max -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAX"
                android:textColor="#6B8CAE"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"/>
            <TextView
                android:id="@+id/tvMax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22°"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </LinearLayout>

        <!-- Séparateur -->
        <View android:layout_width="1dp" android:layout_height="32dp" android:background="#1E3A5F"/>

        <!-- Min -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIN"
                android:textColor="#6B8CAE"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"/>
            <TextView
                android:id="@+id/tvMin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18°"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </LinearLayout>

        <!-- Séparateur -->
        <View android:layout_width="1dp" android:layout_height="32dp" android:background="#1E3A5F"/>

        <!-- Vent -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VENT"
                android:textColor="#6B8CAE"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"/>
            <TextView
                android:id="@+id/tvWind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 km/h"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </LinearLayout>

        <!-- Séparateur -->
        <View android:layout_width="1dp" android:layout_height="32dp" android:background="#1E3A5F"/>

        <!-- Humidité -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HUM."
                android:textColor="#6B8CAE"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"/>
            <TextView
                android:id="@+id/tvHumidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90%"
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!-- TITRE SECTION PRÉVISIONS                   -->
    <!-- ══════════════════════════════════════════ -->
    <TextView
        android:visibility="invisible"
        android:id="@+id/tvForecastTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:text="PRÉVISIONS 7 JOURS"
        android:textColor="#6B8CAE"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:textAllCaps="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llDetails" />

    <!-- ══════════════════════════════════════════ -->
    <!-- CARTE PRÉVISIONS — liste verticale         -->
    <!-- Chaque ligne = 1 jour                      -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:visibility="invisible"
        android:id="@+id/rvForecast"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_card"
        android:padding="4dp"
        android:nestedScrollingEnabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvForecastTitle"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>